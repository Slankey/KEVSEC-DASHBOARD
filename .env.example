# ══════════════════════════════════════════════════════════
#  KEVSEC EXECUTIVE INTELLIGENCE PORTAL — .env.example
#  Copy to .env and fill in values. Never commit .env.
# ══════════════════════════════════════════════════════════

SECRET_KEY=change-me-to-a-long-random-string

# Auth — generate hash: python3 -c "import hashlib; print(hashlib.sha256(b'yourpassword').hexdigest())"
KEVSEC_USERNAME=yourname
KEVSEC_PASSWORD_HASH=sha256-hash-of-your-password

# Proxmox
PROXMOX_HOST=https://YOUR_PROXMOX_IP:8006/api2/json
PROXMOX_USER=user@pve
PROXMOX_PASS=your-proxmox-password

# AbuseIPDB — free at https://www.abuseipdb.com/register
# Enables IP reputation scoring on firewall drop events
ABUSEIPDB_KEY=

# FAA NOTAM API — free at https://external-api.faa.gov/
# Enables live NOTAM/TFR data for KMKE and KETB
FAA_CLIENT_ID=
FAA_CLIENT_SECRET=
